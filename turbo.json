{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": [
    "**/.env",
    "**/.env.local"
  ],
  "globalEnv": [
    "DATABASE_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "KEYCLOAK_URL",
    "REDIS_URL"
  ],
  "pipeline": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "cache": false
    },
    "test:e2e": {
      "outputs": [
        "test-results/**"
      ],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
